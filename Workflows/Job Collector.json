        "jsCode": "// ===== CLEAN TITLE =====\nconst title = ($json.title || '').trim();\nconst titleLower = title.toLowerCase();\n\n// ===== ALLOWED TITLES =====\nconst allowedTitles = [\n  'junior software engineer',\n  'associate software engineer',\n  'graduate engineer trainee',\n  'java developer',\n  'backend developer',\n  'junior frontend developer',\n  'software engineer'\n];\n\n// ===== REJECT SENIOR TITLES =====\nconst rejectedTitles = [\n  'senior',\n  'sr.',\n  'sr ',\n  'lead',\n  'manager',\n  'principal',\n  'staff',\n  'director',\n  'architect',\n  'head',\n  'vp',\n  'vice president',\n  'chief'\n];\n\n// ===== CHECK ALLOWED =====\nconst isAllowed = allowedTitles.some(titlePattern =>\n  titleLower.includes(titlePattern)\n);\n\n// ===== CHECK REJECTED =====\nconst isRejected = rejectedTitles.some(titlePattern =>\n  titleLower.includes(titlePattern)\n);\n\n// ===== FINAL FILTER =====\nif (!isAllowed || isRejected) {\n  return null;\n}"
      },
