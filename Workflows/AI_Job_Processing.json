        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": \"You are a technical recruiter. Analyze this job and return only valid JSON.\\n\\nJob Title: {{$json.job_title}}\\nLocation: {{$json.location}}\\n\\nMy Skills: Java, Spring Boot, MySQL, React, Git.\\n\\nReturn format:\\n{\\n\\\"score\\\":85,\\n\\\"strengths\\\":[\\\"Java\\\"],\\n\\\"missing_skills\\\":[\\\"AWS\\\"]\\n}\"\n        }\n      ]\n    }\n  ]\n}",
        "options": {}
