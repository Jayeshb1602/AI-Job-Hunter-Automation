        "jsCode": "const text =\n$input.first().json.candidates[0].content.parts[0].text;\n\nconst clean = text\n.replace(/```json/g, '')\n.replace(/```/g, '')\n.trim();\n\nconst parsed = JSON.parse(clean);\n\n// Get original job record\nconst job =\n$('Fetch New Jobs(Select rows from a table)').first().json;\n\nreturn [\n{\njson: {\njob_id: job.id,\ngenerated_subject: parsed.subject,\ngenerated_email: parsed.email,\nstatus: 'GENERATED'\n}\n}\n];"
      },
