    {
      "parameters": {
        "jsCode": "const geminiText =\n$input.first().json.candidates[0].content.parts[0].text;\n\nconst cleaned = geminiText\n.replace(/```json/g, '')\n.replace(/```/g, '')\n.trim();\n\nconst result = JSON.parse(cleaned);\n\n// Get original row from Postgres node\nconst job =\n$('Fetch New Jobs(Select rows from a table)').first().json;\n\nreturn [\n{\njson: {\nid: job.id,\nmatch_score: result.score,\nstrengths: result.strengths.join(', '),\nmissing_skills: result.missing_skills.join(', ')\n}\n}\n];"
      },
